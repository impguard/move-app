{
  "expo": {
    "name": "move-app",
    "slug": "move-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon-transparent.png",
    "scheme": "moveapp",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/images/app-icon-ios.png",
      "bundleIdentifier": "com.impzter.moveapp",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#ffffff",
        "foregroundImage": "./assets/images/app-icon-android.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.impzter.moveapp",
      "softwareKeyboardLayoutMode": "pan"
    },
    "web": {
      "output": "single",
      "favicon": "./assets/images/app-icon-web.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#ffffff",
          "image": "./assets/images/splash-icon.png",
          "dark": {
            "backgroundColor": "#121212",
            "image": "./assets/images/splash-icon.png"
          },
          "imageWidth": 76
        }
      ],
      "expo-sharing"
    ],
    "experiments": {
      "baseUrl": "/move-app",
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "e87861b1-f9f4-473f-b0fb-a78eb0fe1dfd"
      }
    }
  }
}
